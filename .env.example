# ─── Logging ─────────────────────────────────────────────────────────
# LOG_LEVEL=DEBUG  # DEBUG for verbose, INFO for normal (default)

# ─── Required: Slack ─────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here

# ─── Required: LLM Provider ─────────────────────────────────────────
# Set the one matching your config/settings.yaml provider.
# Anthropic (default)
ANTHROPIC_API_KEY=sk-ant-your-key-here
# OpenAI
# OPENAI_API_KEY=sk-your-openai-key-here
# Google
# GOOGLE_API_KEY=your-google-api-key-here

# ─── Optional: Notion Second Brain ──────────────────────────────────
# Enable in settings.yaml → integrations.notion.enabled: true
# Not required — intern JDs are stored in local SQLite.
# NOTION_TOKEN=ntn_your-notion-token-here
# NOTION_PARENT_PAGE_ID=your-page-id-here

# ─── Optional: Jira + Confluence ────────────────────────────────────
# Same Atlassian credentials for both Jira and Confluence.
# Enable in settings.yaml → integrations.jira/confluence.enabled: true
# JIRA_SERVER=https://your-org.atlassian.net
# JIRA_EMAIL=you@example.com
# JIRA_API_TOKEN=your-jira-api-token-here
# CONFLUENCE_DEFAULT_SPACE=TEAMSPACE

# ─── Optional: Google OAuth (per-user Calendar + Gmail) ─────────────
# Users connect via: @jibsa connect google
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Optional: Web Tools ────────────────────────────────────────────
# ZENROWS_API_KEY=your-zenrows-api-key-here       # Web reader + search fallback
# GOOGLE_API_KEY=your-google-api-key-here          # Image generation (Nano Banana 2)

# ─── Railway / Persistent Storage ──────────────────────────────────
# Override database paths (e.g. for Railway volume mount at /data).
# Local dev uses defaults: data/jibsa.db, data/credentials.db
# JIBSA_DB_PATH=/data/jibsa.db
# CREDENTIAL_DB_PATH=/data/credentials.db

# ─── Security ───────────────────────────────────────────────────────
# Encryption key for per-user OAuth tokens (Fernet).
# Auto-generated if not set, but tokens won't survive restarts.
# REQUIRED on Railway — generate once and set as secret:
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# CREDENTIAL_ENCRYPTION_KEY=your-fernet-key-here
