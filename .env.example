# Logging: DEBUG for verbose output, INFO for normal (default)
# LOG_LEVEL=DEBUG

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here

# LLM Provider (set the one matching your config/settings.yaml provider)
# Anthropic (default)
ANTHROPIC_API_KEY=sk-ant-your-key-here
# OpenAI
# OPENAI_API_KEY=sk-your-openai-key-here
# Google
# GOOGLE_API_KEY=your-google-api-key-here

# Notion (required for Notion integration + intern storage)
NOTION_TOKEN=ntn_your-notion-token-here

# Notion parent page — Jibsa creates/manages all databases under this page.
# Set this to skip manual database setup. Get the ID from your Notion page URL.
# NOTION_PARENT_PAGE_ID=your-page-id-here

# Jira + Confluence (same Atlassian credentials for both)
JIRA_SERVER=https://your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-jira-api-token-here

# Default Confluence space key (optional — agents can specify per-request)
# CONFLUENCE_DEFAULT_SPACE=TEAMSPACE

# Google OAuth (Phase 3-4: Calendar + Gmail)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ZenRows (web reader tool — fetches full page content)
# ZENROWS_API_KEY=your-zenrows-api-key-here

# Google API key (required for Nano Banana 2 image generation;
# also used if your LLM provider is Google)
# GOOGLE_API_KEY=your-google-api-key-here
