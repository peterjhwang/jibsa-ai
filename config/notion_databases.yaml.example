# Notion databases — Jibsa Second Brain integration
# Copy this file to notion_databases.yaml and fill in your IDs.
# notion_databases.yaml is gitignored — safe to put real IDs there.
#
# No field mapping needed. Jibsa auto-discovers property names from the
# database schema at runtime and passes raw JSON to Claude for reads.
#
# keywords: words in a user message that trigger a query to this database.
# You can paste the full Notion URL or a bare UUID as the id.

notion:
  databases:

    # --- Productivity ---
    - name: Tasks
      id: ""
      keywords: [task, todo, action, to-do]

    - name: Projects
      id: ""
      keywords: [project, build, launch, initiative]

    - name: Goals
      id: ""
      keywords: [goal, aim, objective, target, quarterly]

    - name: Areas
      id: ""
      keywords: [area, responsibility, life area]

    - name: Notes
      id: ""
      keywords: [note, knowledge, idea, resource, info]

    # --- Personal ---
    - name: Journal Entries
      id: ""
      keywords: [journal entry, diary, entry, reflection]

    - name: Habit Tracker
      id: ""
      keywords: [habit, routine, streak, daily]

    - name: Books Library
      id: ""
      keywords: [book, reading, read, author]

    # --- People ---
    - name: Contacts
      id: ""
      keywords: [contact, person, people, follow up]

    - name: Networking & Events
      id: ""
      keywords: [networking, event, meetup, conference]

    # --- Finance ---
    - name: Expense Record
      id: ""
      keywords: [expense, spending, spent, cost, purchase]

    - name: Income Record
      id: ""
      keywords: [income, salary, earnings, revenue]

    - name: Accounts
      id: ""
      keywords: [account, bank, balance, savings]

    - name: Bills & Subscriptions
      id: ""
      keywords: [bill, subscription, recurring, payment]

    # --- Interns (v0.5 multi-intern support) ---
    - name: Interns
      id: ""
      keywords: [intern, hire, team, agent]

    # --- Health & Fitness ---
    - name: Workouts
      id: ""
      keywords: [workout, gym, training, exercise, fitness]

    - name: Meals
      id: ""
      keywords: [meal, food, eat, diet, nutrition, calories]
